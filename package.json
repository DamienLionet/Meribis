{
  "name": "meribis",
  "version": "0.1.0",
  "description": "Recréation du site Meritis — site statique bilingue FR/EN (Eleventy v3 + Tailwind CSS v4 + JS vanilla).",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "eleventy --serve",
    "watch:css": "tailwindcss -i ./src/assets/css/input.css -o ./dist/assets/css/main.css --watch",
    "start": "run-p watch:css dev",
    "build:css": "tailwindcss -i ./src/assets/css/input.css -o ./dist/assets/css/main.css --minify",
    "build": "eleventy",
    "build:js": "node scripts/minify-js.mjs",
    "build:search": "pagefind --site dist",
    "optimize:images": "node scripts/optimize-images.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:all": "run-s clean build:css build build:js build:search",
    "build:local": "cross-env PATH_PREFIX=/ run-s clean build:css build build:js build:search"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tailwindcss/cli": "^4.3.1",
    "cross-env": "^7.0.3",
    "html-minifier-terser": "^7.2.0",
    "npm-run-all2": "^7.0.2",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0"
  }
}
