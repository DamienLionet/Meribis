---
layout: layouts/base.njk
permalink: /fr/offres/
title: Offres d'emploi
translationKey: jobs-index
description: "Rejoignez Meritis : découvrez nos offres d'emploi et candidatez."
---
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <h1 class="text-4xl font-semibold tracking-tight text-brand-charcoal md:text-5xl">{{ title }}</h1>
  <p class="mt-4 max-w-2xl text-lg text-brand-charcoal/70">{{ i18n[locale].jobsIntro }}</p>

  <ul class="mt-12 grid list-none gap-4 p-0">
    {% for post in collections["jobs_" + locale] %}
      {% include "partials/card-job.njk" %}
    {% endfor %}
  </ul>
</section>
