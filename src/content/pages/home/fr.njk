---
layout: layouts/base.njk
permalink: /fr/
title: Accueil
description: "Meritis — conseil en IT, finance et transformation. Des équipes de consultants au service des grands comptes."
---
<section class="relative isolate overflow-hidden bg-brand-blue text-brand-ivory">
  {% set decorClass = "bottom-0 left-0 h-72 w-72 text-white/10 -scale-y-100 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-arcs.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 pt-16 pb-28 md:grid-cols-2 md:pt-24 md:pb-40">
    <div>
      <p class="mb-4 eyebrow text-brand-gold-light">Le groupe Meritis</p>
      <h1 class="display">
        Des experts qui vous conseillent.<br />Une organisation qui délivre.
      </h1>
      <p class="mt-6 max-w-xl lead text-brand-ivory">
        Conseil, expertise opérationnelle et pilotage. Du cadrage stratégique à l'exécution terrain,
        avec +900 experts mobilisables.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="{{ '/fr/contact/' | url }}" class="btn btn-primary">
          Parlons de votre projet
        </a>
        <a href="{{ '/fr/rejoindre-le-groupe/' | url }}" class="btn btn-ghost">
          Rejoindre le groupe
        </a>
      </div>
      <p class="mt-8 flex items-center gap-3 text-brand-ivory/80">
        <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        Engagé pour durer
      </p>
    </div>
    {# Composition superposée : image élevée + cadre or débordant en arrière-plan. #}
    <div class="relative md:justify-self-end">
      <div class="absolute -right-5 -top-5 hidden h-full w-full rounded-card border-2 border-brand-gold/50 md:block" aria-hidden="true"></div>
      <img src="{{ '/assets/images/brand/hero-team.webp' | url }}" alt="L'équipe Meritis" width="900" height="828" loading="eager" decoding="async" class="img-brand relative w-full rounded-card shadow-e3" />
    </div>
  </div>
</section>

{# --- Indicateurs clés : carte surélevée chevauchant la frontière hero / section. --- #}
<div class="relative z-20 mx-auto -mt-16 max-w-6xl px-6 md:-mt-24">
  <div class="grid grid-cols-2 gap-8 rounded-card bg-surface-elevated p-8 shadow-e3 md:grid-cols-4 md:p-10">
    <div class="text-center">
      <p class="stat text-brand-blue">900<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">consultants experts</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">1&nbsp;600<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">clients accompagnés</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">4,5<span class="text-2xl text-brand-gold">/5</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">de satisfaction client</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">B&nbsp;Corp</p>
      <p class="mt-2 text-sm leading-snug text-text-muted">entreprise certifiée à impact</p>
    </div>
  </div>
</div>

{# --- Nos expertises (condensé) --- #}
<section id="expertises" class="relative isolate overflow-hidden bg-white">
  {% set decorClass = "right-[-40px] top-1/2 hidden h-[26rem] w-[26rem] -translate-y-1/2 text-brand-gray md:block" %}
  {% include "partials/decor-bubbles.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
    <div>
      <h2 class="h2 text-brand-charcoal">Nos expertises</h2>
      <p class="mt-4 max-w-md lead text-brand-charcoal">
        Nos +900 consultants vous accompagnent avec agilité sur tous vos projets de transformation
        technologique. Un seul objectif : vous emmener plus loin.
      </p>
      <a href="{{ '/fr/expertises/' | url }}" class="mt-6 link-arrow">
        Toutes nos expertises <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
    <ul class="grid list-none gap-3 p-0 sm:grid-cols-2">
      <li><a href="{{ '/fr/expertises/data-ia/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-data" /></svg><span>Data &amp; IA</span></a></li>
      <li><a href="{{ '/fr/expertises/digital-workspace/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-workspace" /></svg><span>Digital Workspace</span></a></li>
      <li><a href="{{ '/fr/expertises/agile/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-agile" /></svg><span>Agilité</span></a></li>
      <li><a href="{{ '/fr/expertises/cloud/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-cloud" /></svg><span>Cloud</span></a></li>
      <li><a href="{{ '/fr/expertises/devops/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-devops" /></svg><span>DevOps</span></a></li>
      <li><a href="{{ '/fr/expertises/finance/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-finance" /></svg><span>Finance</span></a></li>
      <li><a href="{{ '/fr/expertises/software-factory/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-code" /></svg><span>Software Factory</span></a></li>
      <li><a href="{{ '/fr/expertises/service-cybersecurite/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-shield" /></svg><span>Cybersécurité</span></a></li>
      <li><a href="{{ '/fr/expertises/pilotage-de-projet/' | url }}" class="card card-interactive flex flex-col items-center gap-3 px-5 py-6 text-center font-medium text-brand-blue"><svg class="h-8 w-8 text-brand-gold-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><use href="#i-pilotage" /></svg><span>Pilotage de projet</span></a></li>
    </ul>
  </div>
</section>

{# --- 3 entités, 1 gouvernance --- #}
<section class="surface-gradient text-brand-ivory">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <h2 class="h2">3 entités expertes, 1 gouvernance unifiée</h2>
    <p class="mt-4 max-w-3xl lead text-brand-ivory">
      Le groupe réunit trois entités complémentaires, pour assurer cohérence stratégique, profondeur
      sectorielle et continuité d'exécution.
    </p>
    <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      <li class="card-on-dark p-8">
        <h3 class="h3 text-brand-gold">Navigacom</h3>
        <p class="mt-2 leading-relaxed text-brand-ivory">Architecture stratégique des systèmes d'information.</p>
      </li>
      <li class="card-on-dark p-8">
        <h3 class="h3 text-brand-gold">Neofin Advisory</h3>
        <p class="mt-2 leading-relaxed text-brand-ivory">Transformation des métiers de la Finance et de la CIB.</p>
      </li>
      <li class="card-on-dark p-8">
        <h3 class="h3 text-brand-gold">Meritis</h3>
        <p class="mt-2 leading-relaxed text-brand-ivory">Ingénierie et delivery technologique.</p>
      </li>
    </ul>
  </div>
</section>

{# --- Ils nous font confiance (logos clients) --- #}
<section class="bg-brand-light">
  <div class="mx-auto max-w-6xl px-6 py-14 text-center md:py-16">
    <p class="eyebrow text-brand-gold-deep">Ils nous font confiance</p>
    <h2 class="mt-3 h2 text-brand-charcoal">Des grands comptes dans les secteurs les plus exigeants</h2>
    {% set clients = [["airbus","Airbus"],["air-france","Air France"],["axa","AXA"],["bnp-paribas","BNP Paribas"],["credit-agricole","Crédit Agricole"],["engie","ENGIE"],["essilor","Essilor"],["euronext","Euronext"],["groupama","Groupama"],["hsbc","HSBC"],["la-banque-postale","La Banque Postale"],["mediametrie","Médiamétrie"],["natixis","Natixis"],["orange","Orange"],["oticon-medical","Oticon Medical"],["parrot","Parrot"],["pierre-vacances","Pierre & Vacances"],["ratp","RATP"],["schneider-electric","Schneider Electric"],["societe-generale","Société Générale"],["sncf","SNCF"],["sodern","Sodern"]] %}
    <ul class="mt-10 grid grid-cols-2 items-center justify-items-center gap-x-8 gap-y-8 p-0 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {% for c in clients %}
      <li><img src="{{ ('/assets/images/clients/' + c[0] + '.webp') | url }}" alt="{{ c[1] }}" height="40" loading="lazy" decoding="async" class="h-10 w-auto object-contain opacity-60 grayscale transition hover:opacity-100 hover:grayscale-0" /></li>
      {% endfor %}
    </ul>
  </div>
</section>

{# --- Entreprise à impact (RSE / B Corp) --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="card-feature grid items-center gap-8 p-8 md:grid-cols-[1fr_auto] md:p-12">
    <div>
      <p class="eyebrow text-brand-gold">Entreprise à impact</p>
      <h2 class="mt-3 h2">Performance économique et impact positif</h2>
      <p class="mt-3 max-w-2xl leading-relaxed text-brand-ivory">
        Certifiée B Corp, engagée pour l'égalité professionnelle et un numérique responsable : nous
        plaçons l'humain et l'environnement au cœur de notre modèle.
      </p>
    </div>
    <a href="{{ '/fr/la-rse-chez-meritis/' | url }}" class="btn btn-primary shrink-0">
      Notre engagement RSE
    </a>
  </div>
</section>

{# --- Le blog Meritis --- #}
<section class="bg-brand-light">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="h2 text-brand-charcoal">Le blog Meritis</h2>
        <p class="mt-3 max-w-xl lead text-brand-charcoal">Articles, analyses et retours d'expérience de nos consultants.</p>
      </div>
      <a href="{{ '/fr/blog/' | url }}" class="link-arrow">Tous les articles <span class="arrow" aria-hidden="true">&rarr;</span></a>
    </div>
    <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      {% for post in collections.blog_fr %}{% if loop.index0 < 3 %}{% include "partials/card-blog.njk" %}{% endif %}{% endfor %}
    </ul>
  </div>
</section>

{# --- Rejoignez nos équipes --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="h2 text-brand-charcoal">Rejoignez nos équipes</h2>
      <p class="mt-3 max-w-xl lead text-brand-charcoal">Découvrez nos opportunités et construisez votre parcours chez Meritis.</p>
    </div>
    <a href="{{ '/fr/offres/' | url }}" class="link-arrow">Toutes les offres <span class="arrow" aria-hidden="true">&rarr;</span></a>
  </div>
  <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
    {% for post in collections.jobs_fr %}{% if loop.index0 < 3 %}{% include "partials/card-job.njk" %}{% endif %}{% endfor %}
  </ul>
</section>

{% include "partials/cta-block.njk" %}
