---
layout: layouts/base.njk
permalink: /en/
title: Home
description: "Meritis — IT, finance and transformation consulting. Expert consulting teams serving large accounts."
---
<section class="relative isolate overflow-hidden bg-brand-blue text-brand-ivory">
  {% set decorClass = "bottom-0 left-0 h-72 w-72 text-white/10 -scale-y-100 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-arcs.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 pt-16 pb-28 md:grid-cols-2 md:pt-24 md:pb-40">
    <div>
      <p class="mb-4 eyebrow text-brand-gold-light">The Meritis Group</p>
      <h1 class="display">
        Experts who advise you.<br />An organisation that delivers.
      </h1>
      <p class="mt-6 max-w-xl lead text-brand-ivory">
        Consulting, operational expertise and delivery governance. From strategic scoping to
        on-the-ground execution, with over 900 experts ready to be mobilised.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="{{ '/en/contact/' | url }}" class="btn btn-primary">
          Let's talk about your project
        </a>
        <a href="{{ '/en/join-us/' | url }}" class="btn btn-ghost">
          Join the group
        </a>
      </div>
      <p class="mt-8 flex items-center gap-3 text-brand-ivory/80">
        <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        Committed for the long term
      </p>
    </div>
    {# Layered composition: elevated image + offset gold frame behind. #}
    <div class="relative md:justify-self-end">
      <div class="absolute -right-5 -top-5 hidden h-full w-full rounded-card border-2 border-brand-gold/50 md:block" aria-hidden="true"></div>
      <img src="{{ '/assets/images/brand/hero-team.webp' | url }}" alt="The Meritis team" width="900" height="828" loading="eager" decoding="async" class="img-brand relative w-full rounded-card shadow-e3" />
    </div>
  </div>
</section>

{# --- Key figures: elevated card overlapping the hero / section boundary. --- #}
<div class="relative z-20 mx-auto -mt-16 max-w-6xl px-6 md:-mt-24">
  <div class="grid grid-cols-2 gap-8 rounded-card bg-surface-elevated p-8 shadow-e3 md:grid-cols-4 md:p-10">
    <div class="text-center">
      <p class="stat text-brand-blue">900<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">expert consultants</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">1,600<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">clients supported</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">4.5<span class="text-2xl text-brand-gold">/5</span></p>
      <p class="mt-2 text-sm leading-snug text-text-muted">client satisfaction</p>
    </div>
    <div class="text-center">
      <p class="stat text-brand-blue">B&nbsp;Corp</p>
      <p class="mt-2 text-sm leading-snug text-text-muted">certified impact company</p>
    </div>
  </div>
</div>

{# --- Our expertise (condensed) --- #}
