---
layout: layouts/base.njk
permalink: /en/
title: Home
description: "Meritis — IT, finance and transformation consulting. Expert consulting teams serving large accounts."
---
<section class="relative isolate overflow-hidden bg-brand-blue text-brand-ivory">
  {% set decorClass = "bottom-[-30px] left-[-40px] h-72 w-72 text-white/10 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-bubbles.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-brand-gold-light">Consulting · IT · Finance · Transformation</p>
      <h1 class="text-4xl font-semibold leading-tight tracking-tight md:text-5xl">
        Technology expertise serving large accounts.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-brand-ivory">
        We support our clients' technology transformation with expert consulting teams, through a sober,
        premium and sustainable approach.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#expertise" class="rounded-button bg-brand-gold px-7 py-3 font-semibold text-brand-blue-dark transition hover:bg-brand-gold-dark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-gold">
          Explore our expertise
        </a>
        <a href="{{ '/en/contact/' | url }}" class="rounded-button border border-brand-ivory/40 px-7 py-3 font-semibold text-brand-ivory transition hover:bg-brand-ivory/10 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-ivory">
          Let's talk about your project
        </a>
      </div>
    </div>
    <div class="md:justify-self-end">
      <img src="{{ '/assets/images/brand/hero-team.webp' | url }}" alt="The Meritis team" width="900" height="828" class="w-full rounded-card shadow-soft" />
    </div>
  </div>
</section>

{# --- Key figures --- #}
<section class="border-b border-brand-gray/40 bg-brand-light">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-8 px-6 py-12 text-center md:grid-cols-4 md:py-14">
    <div>
      <p class="text-4xl font-semibold text-brand-blue md:text-5xl">900<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-brand-charcoal">expert consultants</p>
    </div>
    <div>
      <p class="text-4xl font-semibold text-brand-blue md:text-5xl">1,600<span class="text-brand-gold">+</span></p>
      <p class="mt-2 text-sm leading-snug text-brand-charcoal">clients supported</p>
    </div>
    <div>
      <p class="text-4xl font-semibold text-brand-blue md:text-5xl">4.5<span class="text-2xl text-brand-gold">/5</span></p>
      <p class="mt-2 text-sm leading-snug text-brand-charcoal">client satisfaction</p>
    </div>
    <div>
      <p class="text-4xl font-semibold text-brand-blue md:text-5xl">B&nbsp;Corp</p>
      <p class="mt-2 text-sm leading-snug text-brand-charcoal">certified impact company</p>
    </div>
  </div>
</section>

{# --- Our expertise (condensed) --- #}
<section id="expertise" class="relative isolate overflow-hidden bg-white">
  {% set decorClass = "right-[-40px] top-1/2 hidden h-[26rem] w-[26rem] -translate-y-1/2 text-brand-gray md:block" %}
  {% include "partials/decor-bubbles.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
