      <li class="rounded-button bg-white px-5 py-2.5 text-sm font-medium text-brand-blue shadow-sm">Energy</li>
      <li class="rounded-button bg-white px-5 py-2.5 text-sm font-medium text-brand-blue shadow-sm">Transport</li>
      <li class="rounded-button bg-white px-5 py-2.5 text-sm font-medium text-brand-blue shadow-sm">Luxury</li>
      <li class="rounded-button bg-white px-5 py-2.5 text-sm font-medium text-brand-blue shadow-sm">Public sector</li>
    </ul>
  </div>
</section>

{# --- Impact-driven company (CSR / B Corp) --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="grid items-center gap-8 rounded-card bg-brand-blue p-8 text-brand-ivory shadow-soft md:grid-cols-[1fr_auto] md:p-12">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-gold">Impact-driven company</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight md:text-3xl">Economic performance and positive impact</h2>
      <p class="mt-3 max-w-2xl leading-relaxed text-brand-ivory">
        B Corp certified, committed to workplace equality and responsible digital: we place people and
        the environment at the heart of our model.
      </p>
    </div>
    <a href="{{ '/en/meritis-csr/' | url }}" class="shrink-0 rounded-button bg-brand-gold px-7 py-3 font-semibold text-brand-blue-dark transition hover:bg-brand-gold-dark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-gold">
      Our CSR commitment
    </a>
  </div>
</section>

{# --- The Meritis blog --- #}
<section class="bg-brand-light">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-brand-charcoal md:text-4xl">The Meritis blog</h2>
        <p class="mt-3 max-w-xl text-lg text-brand-charcoal">Articles, insights and field experience from our consultants.</p>
      </div>
      <a href="{{ '/en/blog/' | url }}" class="font-semibold text-brand-blue transition hover:text-brand-blue-dark">All articles <span aria-hidden="true">&rarr;</span></a>
    </div>
    <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      {% for post in collections.blog_en %}{% if loop.index0 < 3 %}{% include "partials/card-blog.njk" %}{% endif %}{% endfor %}
    </ul>
  </div>
</section>

{# --- Join our teams --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="text-3xl font-semibold tracking-tight text-brand-charcoal md:text-4xl">Join our teams</h2>
      <p class="mt-3 max-w-xl text-lg text-brand-charcoal">Explore our opportunities and build your career at Meritis.</p>
    </div>
    <a href="{{ '/en/jobs/' | url }}" class="font-semibold text-brand-blue transition hover:text-brand-blue-dark">All jobs <span aria-hidden="true">&rarr;</span></a>
  </div>
  <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
    {% for post in collections.jobs_en %}{% if loop.index0 < 3 %}{% include "partials/card-job.njk" %}{% endif %}{% endfor %}
  </ul>
</section>

