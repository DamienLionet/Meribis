---
layout: layouts/base.njk
permalink: /en/blog/
title: Blog
description: "The Meritis blog: articles, insights and field experience from our consultants."
---
{% set heroTitle = title %}
{% set heroLead = i18n[locale].blogIntro %}
{% include "partials/page-hero.njk" %}

<section class="mx-auto max-w-6xl px-6 py-12 md:py-16">
  {% include "partials/filters-blog.njk" %}
  <ul data-list class="grid list-none gap-6 p-0 md:grid-cols-2">
    {% for post in collections["blog_" + locale] %}
      {% include "partials/card-blog.njk" %}
    {% endfor %}
  </ul>
  <p data-empty hidden class="mt-8 text-brand-charcoal">{{ i18n[locale].noResults }}</p>
</section>
