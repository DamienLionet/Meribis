{% set heroTitle = "Parlons de votre projet" %}
{% set heroLead = "Une question, un projet ou une candidature ? Écrivez-nous via le formulaire ci-dessous — nous revenons vers vous rapidement." %}
{% set heroImage = "/assets/images/brand/hero-contact.webp" %}
{% include "partials/page-hero.njk" %}

<section class="mx-auto max-w-3xl px-6 py-12 md:py-16">
  <div class="overflow-hidden rounded-card bg-white shadow-soft">
    <iframe
      id="contact-form"
      data-source-param="r514c22bc0b9648b2975b6d1a8a495fd5"
      title="Formulaire de contact Meritis"
      src="https://forms.cloud.microsoft/Pages/ResponsePage.aspx?id=FKtmkg0M-k-EhJ7SirQzqpOpZcoB86VIv7udGFyMyOVUNEJINUo3MzRNNVAwMzc5QUdGWUpCRzYyRC4u&embed=true"
      width="100%"
      height="700"
      loading="lazy"
      style="border: 0; max-width: 100%"
      allowfullscreen>
    </iframe>
  </div>
</section>

{# Préremplit le champ « source » du formulaire (id du champ MS Forms) depuis ?source= dans l'URL,
   ex. le titre de l'offre d'emploi d'où vient le clic. Sans JS, le formulaire reste pleinement utilisable. #}
<script>
  (function () {
    var f = document.getElementById("contact-form");
    if (!f) return;
    var source = new URLSearchParams(window.location.search).get("source");
    var param = f.getAttribute("data-source-param");
    if (source && param) f.src = f.src + "&" + param + "=" + encodeURIComponent(source);
  })();
</script>
