---
layout: layouts/base.njk
permalink: /en/jobs/
title: Jobs
description: "Join Meritis: explore our job openings and apply."
---
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <h1 class="text-4xl font-semibold tracking-tight text-brand-charcoal md:text-5xl">{{ title }}</h1>
  <p class="mt-4 max-w-2xl text-lg text-brand-charcoal">{{ i18n[locale].jobsIntro }}</p>

  <ul class="mt-12 grid list-none gap-6 p-0 sm:grid-cols-2 lg:grid-cols-3">
    {% for post in collections["jobs_" + locale] %}
      {% include "partials/card-job.njk" %}
    {% endfor %}
  </ul>
</section>
