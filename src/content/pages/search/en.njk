---
layout: layouts/base.njk
permalink: /en/search/
title: Search
description: "Search Meritis articles, expertise, jobs and news."
---
{% set heroTitle = "Search" %}
{% set heroLead = "Find articles, expertise, jobs and news." %}
{% set noHeroImage = true %}
{% include "partials/page-hero.njk" %}

<section data-pagefind-ignore class="mx-auto max-w-3xl px-6 py-12 md:py-16">
  <link rel="stylesheet" href="{{ '/pagefind/pagefind-ui.css' | url }}" />
  <div id="search"></div>

  {# Empty state: helps navigation until a search is run (hidden as soon as you type). #}
  <div id="search-empty" class="mt-12">
    <div class="js-only">
      <h2 class="eyebrow text-brand-gold-deep">Popular searches</h2>
      <ul class="mt-4 flex flex-wrap gap-2 p-0">
        <li><button type="button" data-search-term="Data &amp; AI" class="chip">Data &amp; AI</button></li>
        <li><button type="button" data-search-term="Cloud" class="chip">Cloud</button></li>
        <li><button type="button" data-search-term="DevOps" class="chip">DevOps</button></li>
        <li><button type="button" data-search-term="Finance" class="chip">Finance</button></li>
        <li><button type="button" data-search-term="Cybersecurity" class="chip">Cybersecurity</button></li>
        <li><button type="button" data-search-term="Agile" class="chip">Agile</button></li>
        <li><button type="button" data-search-term="Generative AI" class="chip">Generative AI</button></li>
      </ul>
    </div>

    <h2 class="eyebrow mt-10 text-brand-gold-deep">Browse the site</h2>
    <ul class="mt-4 grid list-none gap-4 p-0 sm:grid-cols-2">
      <li><a href="{{ '/en/expertise/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Our expertise</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Consulting, engineering and delivery across 9 areas.</span>
      </a></li>
      <li><a href="{{ '/en/blog/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Blog</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Articles, insights and field experience.</span>
      </a></li>
      <li><a href="{{ '/en/jobs/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Jobs</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Our open opportunities.</span>
      </a></li>
      <li><a href="{{ '/en/news/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">News</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Group life and commitments.</span>
      </a></li>
    </ul>
  </div>

  <script src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      if (window.PagefindUI) {
        // Pagefind records URLs WITHOUT the pathPrefix (it indexes dist/ as-is); re-prefix them
        // for /Meribis/ (and nothing locally where PATH_PREFIX=/), otherwise results 404.
        var base = "{{ '/' | url }}".replace(/\/$/, "");
        new PagefindUI({ element: "#search", bundlePath: "{{ '/pagefind/' | url }}", showImages: false, showSubResults: true,
          processResult: function (r) {
            if (r.url) r.url = base + r.url;
            (r.sub_results || []).forEach(function (s) { if (s.url) s.url = base + s.url; });
            return r;
          } });
      }
      var root = document.getElementById("search");
      var empty = document.getElementById("search-empty");
      if (!root || !empty) return;
      function sync() {
        var input = root.querySelector(".pagefind-ui__search-input");
        empty.hidden = !!(input && input.value.trim());
      }
      root.addEventListener("input", sync);
      document.querySelectorAll("[data-search-term]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var input = root.querySelector(".pagefind-ui__search-input");
          if (!input) return;
          input.value = btn.getAttribute("data-search-term");
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
          sync();
        });
      });
      setTimeout(sync, 50);
    });
  </script>
</section>
