---
layout: layouts/base.njk
permalink: /en/search/
title: Search
description: "Search Meritis articles, expertise, jobs and news."
---
{% set heroTitle = "Search" %}
{% set heroLead = "Find articles, expertise, jobs and news." %}
{% set noHeroImage = true %}
{% include "partials/page-hero.njk" %}

<section data-pagefind-ignore class="mx-auto max-w-3xl px-6 py-12 md:py-16">
  <link rel="stylesheet" href="{{ '/pagefind/pagefind-ui.css' | url }}" />
  <div id="search"></div>

  {# Empty state: helps navigation until a search is run (hidden as soon as you type). #}
  <div id="search-empty" class="mt-12">
    <div class="js-only">
      <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-gold-deep">Popular searches</h2>
      <ul class="mt-4 flex flex-wrap gap-2 p-0">
        <li><button type="button" data-search-term="Data &amp; AI" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Data &amp; AI</button></li>
        <li><button type="button" data-search-term="Cloud" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Cloud</button></li>
        <li><button type="button" data-search-term="DevOps" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">DevOps</button></li>
        <li><button type="button" data-search-term="Finance" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Finance</button></li>
        <li><button type="button" data-search-term="Cybersecurity" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Cybersecurity</button></li>
        <li><button type="button" data-search-term="Agile" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Agile</button></li>
        <li><button type="button" data-search-term="Generative AI" class="rounded-button border border-brand-gray/60 bg-white px-4 py-2 text-sm font-medium text-brand-blue transition hover:border-brand-blue hover:bg-brand-light">Generative AI</button></li>
      </ul>
    </div>

    <h2 class="mt-10 text-sm font-semibold uppercase tracking-[0.2em] text-brand-gold-deep">Browse the site</h2>
    <ul class="mt-4 grid list-none gap-4 p-0 sm:grid-cols-2">
      <li><a href="{{ '/en/expertise/' | url }}" class="block h-full rounded-card border border-brand-gray/60 bg-white p-5 transition hover:-translate-y-0.5 hover:border-brand-blue hover:shadow-soft">
        <span class="font-semibold text-brand-blue">Our expertise</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Consulting, engineering and delivery across 9 areas.</span>
      </a></li>
      <li><a href="{{ '/en/blog/' | url }}" class="block h-full rounded-card border border-brand-gray/60 bg-white p-5 transition hover:-translate-y-0.5 hover:border-brand-blue hover:shadow-soft">
        <span class="font-semibold text-brand-blue">Blog</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Articles, insights and field experience.</span>
      </a></li>
      <li><a href="{{ '/en/jobs/' | url }}" class="block h-full rounded-card border border-brand-gray/60 bg-white p-5 transition hover:-translate-y-0.5 hover:border-brand-blue hover:shadow-soft">
        <span class="font-semibold text-brand-blue">Jobs</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Our open opportunities.</span>
      </a></li>
      <li><a href="{{ '/en/news/' | url }}" class="block h-full rounded-card border border-brand-gray/60 bg-white p-5 transition hover:-translate-y-0.5 hover:border-brand-blue hover:shadow-soft">
        <span class="font-semibold text-brand-blue">News</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Group life and commitments.</span>
      </a></li>
    </ul>
  </div>

  <script src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      if (window.PagefindUI) {
        new PagefindUI({ element: "#search", bundlePath: "{{ '/pagefind/' | url }}", showImages: false, showSubResults: true });
      }
      var root = document.getElementById("search");
      var empty = document.getElementById("search-empty");
      if (!root || !empty) return;
      function sync() {
        var input = root.querySelector(".pagefind-ui__search-input");
        empty.hidden = !!(input && input.value.trim());
      }
      root.addEventListener("input", sync);
      document.querySelectorAll("[data-search-term]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var input = root.querySelector(".pagefind-ui__search-input");
          if (!input) return;
          input.value = btn.getAttribute("data-search-term");
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
          sync();
        });
      });
      setTimeout(sync, 50);
    });
  </script>
</section>
