---
layout: layouts/base.njk
permalink: /fr/recherche/
title: Recherche
description: "Recherchez dans les articles, expertises, offres et actualités de Meritis."
---
{% set heroTitle = "Recherche" %}
{% set heroLead = "Trouvez articles, expertises, offres et actualités." %}
{% set noHeroImage = true %}
{% include "partials/page-hero.njk" %}

<section data-pagefind-ignore class="mx-auto max-w-3xl px-6 py-12 md:py-16">
  <link rel="stylesheet" href="{{ '/pagefind/pagefind-ui.css' | url }}" />
  <div id="search"></div>

  {# État vide : aide à la navigation tant qu'aucune recherche n'est lancée (masqué dès qu'on tape). #}
  <div id="search-empty" class="mt-12">
    <div class="js-only">
      <h2 class="eyebrow text-brand-gold-deep">Recherches fréquentes</h2>
      <ul class="mt-4 flex flex-wrap gap-2 p-0">
        <li><button type="button" data-search-term="Data &amp; IA" class="chip">Data &amp; IA</button></li>
        <li><button type="button" data-search-term="Cloud" class="chip">Cloud</button></li>
        <li><button type="button" data-search-term="DevOps" class="chip">DevOps</button></li>
        <li><button type="button" data-search-term="Finance" class="chip">Finance</button></li>
        <li><button type="button" data-search-term="Cybersécurité" class="chip">Cybersécurité</button></li>
        <li><button type="button" data-search-term="Agilité" class="chip">Agilité</button></li>
        <li><button type="button" data-search-term="IA générative" class="chip">IA générative</button></li>
      </ul>
    </div>

    <h2 class="eyebrow mt-10 text-brand-gold-deep">Parcourir le site</h2>
    <ul class="mt-4 grid list-none gap-4 p-0 sm:grid-cols-2">
      <li><a href="{{ '/fr/expertises/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Nos expertises</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Conseil, ingénierie et delivery sur 9 domaines.</span>
      </a></li>
      <li><a href="{{ '/fr/blog/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Blog</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Articles, analyses et retours d'expérience.</span>
      </a></li>
      <li><a href="{{ '/fr/offres/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Offres d'emploi</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">Nos opportunités à pourvoir.</span>
      </a></li>
      <li><a href="{{ '/fr/actualites/' | url }}" class="card card-interactive block h-full p-5">
        <span class="font-semibold text-brand-blue">Actualités</span>
        <span class="mt-1 block text-sm leading-relaxed text-brand-charcoal">La vie et les engagements du groupe.</span>
      </a></li>
    </ul>
  </div>

  <script src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      if (window.PagefindUI) {
        // Pagefind enregistre les URLs SANS le pathPrefix (il indexe dist/ tel quel) ; on les
        // re-préfixe pour /Meribis/ (et rien en local où PATH_PREFIX=/), sinon les résultats 404.
        var base = "{{ '/' | url }}".replace(/\/$/, "");
        new PagefindUI({ element: "#search", bundlePath: "{{ '/pagefind/' | url }}", showImages: false, showSubResults: true,
          processResult: function (r) {
            if (r.url) r.url = base + r.url;
            (r.sub_results || []).forEach(function (s) { if (s.url) s.url = base + s.url; });
            return r;
          } });
      }
      var root = document.getElementById("search");
      var empty = document.getElementById("search-empty");
      if (!root || !empty) return;
      function sync() {
        var input = root.querySelector(".pagefind-ui__search-input");
        empty.hidden = !!(input && input.value.trim());
      }
      root.addEventListener("input", sync);
      document.querySelectorAll("[data-search-term]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var input = root.querySelector(".pagefind-ui__search-input");
          if (!input) return;
          input.value = btn.getAttribute("data-search-term");
          input.dispatchEvent(new Event("input", { bubbles: true }));
          input.focus();
          sync();
        });
      });
      setTimeout(sync, 50);
    });
  </script>
</section>
