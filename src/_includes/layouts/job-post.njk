---
layout: layouts/base.njk
---
{% set jobsListUrl = "/fr/offres/" if locale == "fr" else "/en/jobs/" %}
{% set parent = { "label": i18n[locale].jobs, "url": jobsListUrl } %}
<article class="mx-auto max-w-3xl px-6 py-12 md:py-16">
  {% include "partials/breadcrumbs.njk" %}

  <header class="mt-6">
    <h1 class="text-4xl font-semibold tracking-tight text-brand-charcoal md:text-5xl">{{ title }}</h1>
    {% if summary %}<p class="mt-4 text-xl leading-relaxed text-brand-charcoal">{{ summary }}</p>{% endif %}

    <dl class="mt-6 grid grid-cols-2 gap-4 rounded-card bg-white p-6 shadow-soft sm:grid-cols-3">
      {% if contract %}<div><dt class="text-xs uppercase tracking-wider text-brand-charcoal">{{ i18n[locale].contract }}</dt><dd class="mt-1 font-medium text-brand-blue">{{ contract }}</dd></div>{% endif %}
      {% if location %}<div><dt class="text-xs uppercase tracking-wider text-brand-charcoal">{{ i18n[locale].location }}</dt><dd class="mt-1 font-medium text-brand-blue">{{ location }}</dd></div>{% endif %}
      {% if remote %}<div><dt class="text-xs uppercase tracking-wider text-brand-charcoal">{{ i18n[locale].remote }}</dt><dd class="mt-1 font-medium text-brand-blue">{{ remote }}</dd></div>{% endif %}
      {% if businessLine %}<div><dt class="text-xs uppercase tracking-wider text-brand-charcoal">{{ i18n[locale].businessLine }}</dt><dd class="mt-1 font-medium text-brand-blue">{{ businessLine }}</dd></div>{% endif %}
      {% if experience %}<div><dt class="text-xs uppercase tracking-wider text-brand-charcoal">{{ i18n[locale].experience }}</dt><dd class="mt-1 font-medium text-brand-blue">{{ experience }}</dd></div>{% endif %}
    </dl>
  </header>

  <div class="prose-meritis mt-8">
    {{ content | safe }}
  </div>

  {% if skills %}
  <div class="mt-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-gold-deep">{{ i18n[locale].skills }}</h2>
    <ul class="mt-3 flex flex-wrap gap-2 p-0">
      {% for s in skills %}<li class="rounded-button bg-brand-light px-3 py-1 text-sm text-brand-charcoal">{{ s }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}

  <div class="mt-10 flex flex-wrap items-center gap-5">
    <a href="{% if applyUrl %}{{ applyUrl | url }}{% else %}{{ ('/' + locale + '/contact/') | url }}?source={{ title | urlencode }}{% endif %}" class="rounded-button bg-brand-gold px-7 py-3 font-semibold text-brand-blue-dark transition hover:bg-brand-gold-dark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-gold">{{ i18n[locale].apply }}</a>
    <a href="{{ parent.url | url }}" class="font-semibold text-brand-blue transition hover:text-brand-blue-dark">← {{ i18n[locale].backToJobs }}</a>
  </div>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": {{ title | dump | safe }},
  "description": {{ (summary or title) | dump | safe }},
  "datePosted": "{{ page.date | isoDate }}",
  {% if contract %}"employmentType": {{ contract | dump | safe }},{% endif %}
  {% if location %}"jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": {{ location | dump | safe }}, "addressCountry": "FR" } },{% endif %}
  "hiringOrganization": { "@type": "Organization", "name": "{{ site.name }}" },
  "url": "{{ site.url }}{{ page.url | url }}"
}
</script>
