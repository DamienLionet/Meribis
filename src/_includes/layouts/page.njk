---
layout: layouts/base.njk
---
{% if heroImage %}
{% set heroTitle = title %}
{% set heroLead = lead %}
{% include "partials/page-hero.njk" %}
<article class="mx-auto max-w-5xl px-6 py-12 md:py-16">
  <div class="prose-meritis">
    {{ content | safe }}
  </div>
</article>
{% else %}
<article class="mx-auto max-w-5xl px-6 py-12 md:py-16">
  {% include "partials/breadcrumbs.njk" %}

  <header class="mt-6">
    <h1 class="text-4xl font-semibold tracking-tight text-brand-charcoal md:text-5xl">{{ title }}</h1>
    {% if lead %}<p class="mt-4 text-xl leading-relaxed text-brand-charcoal">{{ lead }}</p>{% endif %}
  </header>

  <div class="prose-meritis mt-8">
    {{ content | safe }}
  </div>
</article>
{% endif %}

{% if not noCta %}{% include "partials/cta-block.njk" %}{% endif %}
