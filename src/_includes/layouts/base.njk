<!doctype html>
<html lang="{{ locale or site.lang }}" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {# Démo interne (refonte de meritis.fr) : on empêche l'indexation par les moteurs.
       Sur une project page GitHub, robots.txt (sous /Meribis/) n'est pas lu à la racine
       d'hôte — seul ce meta « noindex » est fiable. À retirer pour une vraie mise en ligne. #}
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href="{{ '/assets/favicons/favicon.svg' | url }}" type="image/svg+xml" />
    <link rel="icon" href="{{ '/assets/favicons/favicon-32.png' | url }}" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="{{ '/assets/favicons/apple-touch-icon.png' | url }}" />
    <meta name="theme-color" content="#0a3840" />

    <title>{% if title %}{{ title }} · {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url | url }}" />

    {% for loc in site.locales %}
      {%- if translations and translations[loc] %}
    <link rel="alternate" hreflang="{{ loc }}" href="{{ site.url }}{{ translations[loc] | url }}" />
      {%- endif %}
    {%- endfor %}
    {%- if translations and translations[site.defaultLocale] %}
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ translations[site.defaultLocale] | url }}" />
    {%- endif %}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.name }}{% endif %}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url | url }}" />
    <meta property="og:locale" content="{{ locale or site.lang }}" />
    <meta property="og:image" content="{{ site.url }}{{ (image or '/assets/images/brand/hero-team.webp') | url }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{% if title %}{{ title }}{% else %}{{ site.name }}{% endif %}" />
    <meta name="twitter:description" content="{{ description or site.description }}" />
    <meta name="twitter:image" content="{{ site.url }}{{ (image or '/assets/images/brand/hero-team.webp') | url }}" />

    <link rel="preload" href="{{ '/assets/fonts/quicksand.woff2' | url }}" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="{{ '/assets/fonts/aptos-regular.woff2' | url }}" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="{{ '/assets/fonts/aptos-semibold.woff2' | url }}" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
  </head>
  <body class="flex min-h-screen flex-col bg-brand-ivory font-sans text-brand-charcoal antialiased">
    <a href="#contenu" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-button focus:bg-brand-gold focus:px-5 focus:py-2 focus:font-semibold focus:text-brand-blue-dark">{{ i18n[locale].skipToContent }}</a>

    {% include "partials/icon-sprite.njk" %}

    {% include "partials/header.njk" %}

    <main id="contenu" class="flex-1">
      {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    <script type="module" src="{{ '/assets/js/main.js' | url }}"></script>
    <script type="module" src="{{ '/assets/js/filters.js' | url }}"></script>
  </body>
</html>
