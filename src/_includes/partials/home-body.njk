{# Corps de la page d'accueil — structure unique FR/EN. Copie : _data/home.js. URLs :
   _data/routes.js. Entités : _data/entities.js. Expertises : _data/expertisesNav.js. #}
{% import "partials/macros.njk" as ui %}
{% set h = home[locale] %}

{# --- Hero : composition superposée (image élevée + cadre or débordant). --- #}
<section class="relative isolate overflow-hidden bg-brand-blue text-brand-ivory">
  {% set decorClass = "bottom-0 left-0 h-72 w-72 text-white/10 -scale-y-100 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-arcs.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 pt-16 pb-28 md:grid-cols-2 md:pt-24 md:pb-40">
    <div>
      <p class="mb-4 eyebrow text-brand-gold-light">{{ h.heroEyebrow }}</p>
      <h1 class="display">{{ h.heroTitle | safe }}</h1>
      <p class="mt-6 max-w-xl lead text-brand-ivory">{{ h.heroLead }}</p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="{{ routes.contact[locale] | url }}" class="btn btn-primary">{{ h.ctaPrimaryLabel }}</a>
        <a href="{{ routes.joinGroup[locale] | url }}" class="btn btn-ghost">{{ h.ctaGhostLabel }}</a>
      </div>
      <p class="mt-8 flex items-center gap-3 text-brand-ivory/80">
        <span class="h-px w-8 bg-brand-gold" aria-hidden="true"></span>
        {{ h.heroTagline }}
      </p>
    </div>
    <div class="relative md:justify-self-end">
      <div class="absolute -right-5 -top-5 hidden h-full w-full rounded-card border-2 border-brand-gold/50 md:block" aria-hidden="true"></div>
      <img src="{{ '/assets/images/brand/hero-team.webp' | url }}" alt="{{ h.heroImageAlt }}" width="900" height="828" loading="eager" decoding="async" class="img-brand relative w-full rounded-card shadow-e3" />
    </div>
  </div>
</section>

{# --- Indicateurs clés : carte surélevée chevauchant la frontière hero / section. --- #}
<div class="relative z-20 mx-auto -mt-16 max-w-6xl px-6 md:-mt-24">
  <div class="grid grid-cols-2 gap-8 rounded-card bg-surface-elevated p-8 shadow-e3 md:grid-cols-4 md:p-10">
    {% for s in h.stats %}{{ ui.stat(s.value, s.label) }}{% endfor %}
  </div>
</div>

{# --- Nos expertises (condensé) --- #}
<section id="expertises" class="relative isolate overflow-hidden bg-white">
  {% set decorClass = "right-[-40px] top-1/2 hidden h-[26rem] w-[26rem] -translate-y-1/2 text-brand-gray md:block" %}
  {% include "partials/decor-bubbles.njk" %}
  <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 md:grid-cols-2 md:py-24">
    <div>
      <h2 class="h2 text-brand-charcoal">{{ h.expTitle }}</h2>
      <p class="mt-4 max-w-md lead text-brand-charcoal">{{ h.expLead }}</p>
      <a href="{{ routes.expertises[locale] | url }}" class="mt-6 link-arrow">{{ h.expLinkLabel }} <span class="arrow" aria-hidden="true">&rarr;</span></a>
    </div>
    <ul class="grid list-none gap-3 p-0 sm:grid-cols-2">
      {% for id in expertisesNav.order %}{% set e = expertisesNav.items[locale][id] %}{{ ui.tile(e.url, e.icon, e.label) }}{% endfor %}
    </ul>
  </div>
</section>

{# --- 3 entités, 1 gouvernance --- #}
<section class="surface-gradient text-brand-ivory">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <h2 class="h2">{{ h.entTitle }}</h2>
    <p class="mt-4 max-w-3xl lead text-brand-ivory">{{ h.entLead }}</p>
    <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      {% for e in entities[locale] %}
      <li class="card-on-dark p-8">
        <h3 class="h3 text-brand-gold">{{ e.name }}</h3>
        <p class="mt-2 leading-relaxed text-brand-ivory">{{ e.desc }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

{# --- Ils nous font confiance (logos clients ; liste partagée, identique FR/EN) --- #}
<section class="bg-brand-light">
  <div class="mx-auto max-w-6xl px-6 py-14 text-center md:py-16">
    <p class="eyebrow text-brand-gold-deep">{{ h.clientsEyebrow }}</p>
    <h2 class="mt-3 h2 text-brand-charcoal">{{ h.clientsTitle }}</h2>
    {% set clients = [["airbus","Airbus"],["air-france","Air France"],["axa","AXA"],["bnp-paribas","BNP Paribas"],["credit-agricole","Crédit Agricole"],["engie","ENGIE"],["essilor","Essilor"],["euronext","Euronext"],["groupama","Groupama"],["hsbc","HSBC"],["la-banque-postale","La Banque Postale"],["mediametrie","Médiamétrie"],["natixis","Natixis"],["orange","Orange"],["oticon-medical","Oticon Medical"],["parrot","Parrot"],["pierre-vacances","Pierre & Vacances"],["ratp","RATP"],["schneider-electric","Schneider Electric"],["societe-generale","Société Générale"],["sncf","SNCF"],["sodern","Sodern"]] %}
    <ul class="mt-10 grid grid-cols-2 items-center justify-items-center gap-x-8 gap-y-8 p-0 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {% for c in clients %}
      <li><img src="{{ ('/assets/images/clients/' + c[0] + '.webp') | url }}" alt="{{ c[1] }}" height="40" loading="lazy" decoding="async" class="h-10 w-auto object-contain opacity-60 grayscale transition hover:opacity-100 hover:grayscale-0" /></li>
      {% endfor %}
    </ul>
  </div>
</section>

{# --- Entreprise à impact (RSE / B Corp) --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="card-feature grid items-center gap-8 p-8 md:grid-cols-[1fr_auto] md:p-12">
    <div>
      <p class="eyebrow text-brand-gold">{{ h.rseEyebrow }}</p>
      <h2 class="mt-3 h2">{{ h.rseTitle }}</h2>
      <p class="mt-3 max-w-2xl leading-relaxed text-brand-ivory">{{ h.rseText }}</p>
    </div>
    <a href="{{ routes.rse[locale] | url }}" class="btn btn-primary shrink-0">{{ h.rseCtaLabel }}</a>
  </div>
</section>

{# --- Le blog Meritis --- #}
<section class="bg-brand-light">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="h2 text-brand-charcoal">{{ h.blogTitle }}</h2>
        <p class="mt-3 max-w-xl lead text-brand-charcoal">{{ h.blogLead }}</p>
      </div>
      <a href="{{ routes.blog[locale] | url }}" class="link-arrow">{{ h.blogLinkLabel }} <span class="arrow" aria-hidden="true">&rarr;</span></a>
    </div>
    <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      {% for post in collections["blog_" + locale] %}{% if loop.index0 < 3 %}{% include "partials/card-blog.njk" %}{% endif %}{% endfor %}
    </ul>
  </div>
</section>

{# --- Rejoignez nos équipes --- #}
<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="h2 text-brand-charcoal">{{ h.jobsTitle }}</h2>
      <p class="mt-3 max-w-xl lead text-brand-charcoal">{{ h.jobsLead }}</p>
    </div>
    <a href="{{ routes.jobs[locale] | url }}" class="link-arrow">{{ h.jobsLinkLabel }} <span class="arrow" aria-hidden="true">&rarr;</span></a>
  </div>
  <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
    {% for post in collections["jobs_" + locale] %}{% if loop.index0 < 3 %}{% include "partials/card-job.njk" %}{% endif %}{% endfor %}
  </ul>
</section>

{% include "partials/cta-block.njk" %}
