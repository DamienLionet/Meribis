{% set searchUrl = "/fr/recherche/" if locale == "fr" else "/en/search/" %}
<header class="sticky top-0 z-40 border-b border-brand-gray/50 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="{{ ('/' + locale + '/') | url }}" class="shrink-0" aria-label="Meritis — {{ i18n[locale].home }}">
      <img src="{{ '/assets/images/brand/logo.webp' | url }}" width="1024" height="181" alt="Meritis" loading="eager" decoding="async" class="h-8 w-auto md:h-9" />
    </a>

    <div class="flex items-center gap-4 md:gap-6">
      <nav class="hidden md:block" aria-label="{{ i18n[locale].mainNav }}">
        <ul class="flex items-center gap-7">
          {% for item in navigation[locale] %}
            {% if item.children %}
              {% set isActive = ("#" not in item.url) and (item.url in page.url) %}
              <li class="group relative">
                <button type="button" data-dropdown-toggle aria-haspopup="true" aria-expanded="false" class="inline-flex items-center gap-1 text-sm font-medium {% if isActive %}text-brand-blue{% else %}text-brand-charcoal transition hover:text-brand-blue{% endif %}">
                  {{ item.label }}
                  <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </button>
                <ul data-dropdown-menu class="absolute left-0 top-full z-50 mt-1 min-w-[15rem] rounded-card border border-brand-gray/50 bg-white p-2 shadow-soft">
                  {% for child in item.children %}
                    <li><a href="{{ child.url | url }}" class="block rounded px-3 py-2 text-sm text-brand-charcoal transition hover:bg-brand-light hover:text-brand-blue">{{ child.label }}</a></li>
                  {% endfor %}
                </ul>
              </li>
            {% else %}
              {% set isActive = ("#" not in item.url) and (page.url == item.url) %}
              <li>
                <a href="{{ item.url | url }}"{% if isActive %} aria-current="page"{% endif %} class="text-sm font-medium {% if isActive %}text-brand-blue{% else %}text-brand-charcoal transition hover:text-brand-blue{% endif %}">{{ item.label }}</a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </nav>

      <a href="{{ searchUrl | url }}" class="hidden text-brand-charcoal transition hover:text-brand-blue md:inline-flex" aria-label="{{ i18n[locale].search }}" title="{{ i18n[locale].search }}">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" stroke-linecap="round" /></svg>
      </a>

      {% include "partials/language-switcher.njk" %}

      <a href="{{ ('/' + locale + '/contact/') | url }}" class="hidden rounded-button bg-brand-blue px-5 py-2 text-sm font-semibold text-white transition hover:bg-brand-blue-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue md:inline-flex">{{ i18n[locale].contact }}</a>

      <button type="button" data-menu-toggle aria-controls="mobile-menu" aria-expanded="false" aria-label="{{ i18n[locale].openMenu }}" data-label-open="{{ i18n[locale].openMenu }}" data-label-close="{{ i18n[locale].closeMenu }}" class="inline-flex items-center justify-center rounded p-2 text-brand-charcoal transition hover:bg-brand-light md:hidden">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" /></svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" data-mobile-menu aria-label="{{ i18n[locale].menu }}" class="border-t border-brand-gray/50 bg-white md:hidden">
    <ul class="space-y-1 px-6 py-4">
      {% for item in navigation[locale] %}
        {% if item.children %}
          <li>
            <span class="block px-3 pt-2 text-xs font-semibold uppercase tracking-wider text-brand-charcoal">{{ item.label }}</span>
            <ul class="space-y-1">
              {% for child in item.children %}
                <li><a href="{{ child.url | url }}" class="block rounded px-3 py-2 text-base text-brand-charcoal transition hover:bg-brand-light">{{ child.label }}</a></li>
              {% endfor %}
            </ul>
          </li>
        {% else %}
          {% set isActive = ("#" not in item.url) and (page.url == item.url) %}
          <li>
            <a href="{{ item.url | url }}"{% if isActive %} aria-current="page"{% endif %} class="block rounded px-3 py-2 text-base font-medium {% if isActive %}bg-brand-light text-brand-blue{% else %}text-brand-charcoal transition hover:bg-brand-light{% endif %}">{{ item.label }}</a>
          </li>
        {% endif %}
      {% endfor %}
      <li>
        <a href="{{ searchUrl | url }}" class="block rounded px-3 py-2 text-base font-medium text-brand-charcoal transition hover:bg-brand-light">{{ i18n[locale].search }}</a>
      </li>
      <li>
        <a href="{{ ('/' + locale + '/contact/') | url }}" class="mt-2 block rounded-button bg-brand-blue px-3 py-2 text-center text-base font-semibold text-white">{{ i18n[locale].contact }}</a>
      </li>
    </ul>
  </nav>
</header>
