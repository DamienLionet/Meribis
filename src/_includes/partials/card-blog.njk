<li class="flex flex-col overflow-hidden rounded-card bg-white shadow-soft transition hover:-translate-y-0.5">
  <div class="flex flex-1 flex-col p-6">
    {% if post.data.category %}<span class="text-sm font-semibold text-brand-gold-dark">{{ post.data.category }}</span>{% endif %}
    <h3 class="mt-2 text-xl font-semibold text-brand-blue">
      <a href="{{ post.url | url }}" class="transition hover:underline">{{ post.data.title }}</a>
    </h3>
    {% if post.data.excerpt %}<p class="mt-3 flex-1 leading-relaxed text-brand-charcoal/75">{{ post.data.excerpt }}</p>{% endif %}
    <p class="mt-4 text-sm text-brand-charcoal/55">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | displayDate(locale) }}</time>{% if post.data.author %} · {{ post.data.author }}{% endif %}
    </p>
  </div>
</li>
