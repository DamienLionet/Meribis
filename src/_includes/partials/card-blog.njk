<li data-category="{{ post.data.category }}" class="card card-interactive group relative flex flex-col overflow-hidden">
  {% if post.data.image %}
  <div class="aspect-[1200/628] overflow-hidden bg-brand-light">
    <img src="{{ post.data.image | url }}" alt="{{ post.data.imageAlt or post.data.title }}" width="1200" height="628" loading="lazy" decoding="async" class="img-brand h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]" />
  </div>
  {% endif %}
  <div class="flex flex-1 flex-col p-6">
    {% if post.data.category %}<span class="text-sm font-semibold text-brand-gold-deep">{{ post.data.category }}</span>{% endif %}
    <h3 class="h3 mt-2 line-clamp-2 text-brand-blue">
      <a href="{{ post.url | url }}" class="after:absolute after:inset-0 after:content-[''] group-hover:underline">{{ post.data.title }}</a>
    </h3>
    {% if post.data.excerpt %}<p class="mt-3 line-clamp-3 flex-1 leading-relaxed text-brand-charcoal">{{ post.data.excerpt }}</p>{% endif %}
    <p class="mt-4 text-sm text-brand-charcoal">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | displayDate(locale) }}</time>{% if post.data.author %} · {{ post.data.author }}{% endif %}
    </p>
  </div>
</li>
