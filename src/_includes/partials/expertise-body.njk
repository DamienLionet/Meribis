{# Corps de la page Expertises — structure unique FR/EN. Copie : _data/expertise.js ;
   entités : _data/entities.js ; tuiles : _data/expertisesNav.js. #}
{% import "partials/macros.njk" as ui %}
{% set d = expertise[locale] %}
{% set heroTitle = d.heroTitle %}
{% set heroLead = d.heroLead %}
{% set noHeroImage = true %}
{% include "partials/page-hero.njk" %}

<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="grid items-center gap-10 md:grid-cols-3">
    <div class="md:col-span-2">
      <h2 class="h2 text-brand-charcoal">{{ d.introTitle }}</h2>
      <p class="lead mt-4 text-brand-charcoal">{{ d.introText }}</p>
    </div>
    <div class="card-feature p-8 text-center">
      <p class="stat">{{ d.satStat | safe }}</p>
      <p class="mt-3 text-sm leading-relaxed text-brand-ivory">{{ d.satText | safe }}</p>
    </div>
  </div>
</section>

<section class="border-y border-brand-gray/50 bg-white py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="h2 text-brand-charcoal">{{ d.domainsTitle }}</h2>
    <div class="mt-12 flex flex-col gap-14">
      {% for dom in d.domains %}
      {% set swap = loop.index % 2 == 0 %}
      <article class="grid items-center gap-8 md:grid-cols-2">
        <img src="{{ dom.img | url }}" alt="{{ dom.alt }}" width="800" height="533" loading="lazy" class="img-brand w-full rounded-card shadow-soft{% if swap %} md:order-2{% endif %}" />
        <div{% if swap %} class="md:order-1"{% endif %}>
          <h3 class="h3 text-brand-blue">{{ dom.title }}</h3>
          <p class="mt-3 leading-relaxed text-brand-charcoal">{{ dom.desc }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <h2 class="h2 text-brand-charcoal">{{ d.modelTitle }}</h2>
  <p class="lead mt-4 max-w-3xl text-brand-charcoal">{{ d.modelLead }}</p>
  <ul class="mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
    {% for e in entities[locale] %}
    <li class="card p-8">
      <h3 class="h3 text-brand-blue">{{ e.name }}</h3>
      <p class="mt-2 leading-relaxed text-brand-charcoal">{{ e.desc }}</p>
    </li>
    {% endfor %}
  </ul>
</section>

{% if d.showExplore %}
<section class="mx-auto max-w-6xl px-6 pb-16 md:pb-20">
  <h2 class="h2 text-brand-charcoal">{{ d.exploreTitle }}</h2>
  <ul class="mt-8 grid list-none gap-3 p-0 sm:grid-cols-2 lg:grid-cols-3">
    {% for id in expertisesNav.order %}{% set e = expertisesNav.items[locale][id] %}{{ ui.tile(e.url, e.icon, e.label) }}{% endfor %}
  </ul>
</section>
{% endif %}

{% include "partials/cta-block.njk" %}
