<li data-contract="{{ post.data.contract }}" data-location="{{ post.data.location }}" data-businessline="{{ post.data.businessLine }}" class="card card-interactive group relative flex flex-col p-6">
  <h3 class="h3 text-brand-blue">
    <a href="{{ post.url | url }}" class="after:absolute after:inset-0 after:content-[''] group-hover:underline">{{ post.data.title }}</a>
  </h3>
  <ul class="mt-3 flex flex-1 flex-wrap content-start gap-2 p-0 text-xs">
    {% if post.data.contract %}<li class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand-charcoal">{{ post.data.contract }}</li>{% endif %}
    {% if post.data.location %}<li class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand-charcoal">{{ post.data.location }}</li>{% endif %}
    {% if post.data.remote %}<li class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand-charcoal">{{ post.data.remote }}</li>{% endif %}
    {% if post.data.businessLine %}<li class="rounded-full bg-brand-light px-2.5 py-1 font-medium text-brand-charcoal">{{ post.data.businessLine }}</li>{% endif %}
  </ul>
  <span class="mt-4 text-sm font-semibold text-brand-blue group-hover:underline">{{ i18n[locale].viewJob }} →</span>
</li>
