{# Hero de page habillé : fond bleu nuit.
   Variables avant l'include :
   - heroTitle (requis), heroLead (optionnel)
   - heroImage : chemin de l'image latérale (défaut : hero-bg.webp)
   - noHeroImage : true => pas d'image, affiche des bulles décoratives à la place.
   Image et bulles sont exclusives : pas de bulles quand il y a une photo. #}
<section class="surface-gradient relative isolate overflow-hidden text-brand-ivory">
  {% if not noHeroImage %}
  <div class="pointer-events-none absolute inset-y-0 right-0 hidden w-1/2 lg:block" aria-hidden="true">
    <img src="{{ (heroImage or '/assets/images/brand/hero-bg.webp') | url }}" alt="" width="1024" height="683" class="hero-media-mask img-brand h-full w-full object-cover" />
  </div>
  {% else %}
  {% set decorClass = "right-0 top-0 h-72 w-72 text-white/10 -scale-x-100 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-arcs.njk" %}
  {% endif %}
  <div class="relative z-10 mx-auto max-w-6xl px-6 py-16 md:py-20">
    <h1 class="h1">{{ heroTitle }}</h1>
    {% if heroLead %}<p class="lead mt-4 max-w-2xl text-brand-ivory">{{ heroLead }}</p>{% endif %}
  </div>
</section>
