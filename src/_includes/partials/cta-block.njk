<section id="contact" class="surface-gradient relative isolate overflow-hidden text-brand-ivory">
  {% set decorClass = "right-0 bottom-0 h-72 w-72 text-white/10 rotate-180 md:h-[26rem] md:w-[26rem]" %}
  {% include "partials/decor-arcs.njk" %}
  <div class="relative z-10 mx-auto flex max-w-6xl flex-col items-start gap-8 px-6 py-20 md:flex-row md:items-center md:justify-between">
    <div>
      <h2 class="h2">{{ cta.title or i18n[locale].ctaTitle }}</h2>
      <p class="lead mt-3 max-w-xl text-brand-ivory">{{ cta.text or i18n[locale].ctaText }}</p>
    </div>
    <a href="{{ routes.contact[locale] | url }}" class="btn btn-primary shrink-0">
      {{ cta.label or i18n[locale].contact }}
    </a>
  </div>
</section>
