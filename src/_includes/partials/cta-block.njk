<section id="contact" class="relative isolate overflow-hidden bg-brand-blue-dark text-brand-ivory">
  {% set decorClass = "right-[-24px] bottom-[-32px] h-64 w-64 text-white/10" %}
  {% include "partials/decor-bubbles.njk" %}
  <div class="relative z-10 mx-auto flex max-w-6xl flex-col items-start gap-8 px-6 py-20 md:flex-row md:items-center md:justify-between">
    <div>
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{{ cta.title or i18n[locale].ctaTitle }}</h2>
      <p class="mt-3 max-w-xl text-lg text-brand-ivory">{{ cta.text or i18n[locale].ctaText }}</p>
    </div>
    <a href="{{ ('/' + locale + '/contact/') | url }}" class="shrink-0 rounded-button bg-brand-gold px-7 py-3 font-semibold text-brand-blue-dark transition hover:bg-brand-gold-dark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-gold">
      {{ cta.label or i18n[locale].contact }}
    </a>
  </div>
</section>
